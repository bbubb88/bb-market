// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 用户
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   // 可选手机号
  discordId     String?   @unique // Discord ID
  discordTag    String?   // Discord 用户名
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  listings      Listing[] // 发布的商品
  buyerOrders   Order[]   @relation("BuyerOrders") // 订单（买家）
  sellerOrders  Order[]   @relation("SellerOrders") // 销售（卖家）
  favorites     Favorite[]
  wallet        Wallet?
}

// 钱包
model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(20, 8)
  frozen    Decimal  @default(0) @db.Decimal(20, 8) // 冻结金额
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

// 游戏
model Game {
  id          String   @id @default(cuid())
  name        String   // 游戏名称
  nameKo      String   // 韩文名称
  icon        String?  // 图标emoji
  iconUrl     String?  // 图标URL
  status      GameStatus @default(ACTIVE)
  createdAt   DateTime @default(now())

  listings    Listing[]
  servers     Server[]
}

enum GameStatus {
  ACTIVE
  COMING
  DISABLED
}

// 服务器
model Server {
  id        String   @id @default(cuid())
  gameId    String
  name      String   // 服务器名称
  nameKo    String   // 韩文名称
  zone      String   // 大区
  createdAt DateTime @default(now())

  game      Game     @relation(fields: [gameId], references: [id])
  listings  Listing[]
}

// 商品
model Listing {
  id            String        @id @default(cuid())
  sellerId      String
  gameId        String
  serverId      String?
  type          ListingType   // account/item/coin
  title         String
  titleKo       String?
  description   String?
  descriptionKo String?
  price         Decimal       @db.Decimal(20, 8) // USDT价格
  level         Int?          // 账号等级
  amount        Int?          // 数量（游戏币/道具）
  images        String[]      // 图片JSON数组
  badge         String?       // 标签
  status        ListingStatus @default(SELLING)
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  seller        User          @relation(fields: [sellerId], references: [id])
  game          Game          @relation(fields: [gameId], references: [id])
  server        Server?       @relation(fields: [serverId], references: [id])
  orders        Order[]
  favorites    Favorite[]
}

enum ListingType {
  ACCOUNT
  ITEM
  COIN
}

enum ListingStatus {
  SELLING      // 出售中
  TRADING      // 交易中
  SOLD         // 已出售
  OFFLINE      // 已下架
}

// 订单
model Order {
  id            String      @id @default(cuid())
  listingId     String
  buyerId       String
  sellerId      String
  price         Decimal     @db.Decimal(20, 8)
  fee           Decimal     @default(0) @db.Decimal(20, 8) // 手续费5%
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  listing       Listing     @relation(fields: [listingId], references: [id])
  buyer         User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller        User        @relation("SellerOrders", fields: [sellerId], references: [id])
}

enum OrderStatus {
  PENDING      // 待确认
  PAID         // 已付款
  DELIVERING  // 发货中
  COMPLETED   // 已完成
  CANCELLED   // 已取消
  DISPUTED    // 争议中
}

// 收藏
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@unique([userId, listingId])
}

// 系统设置
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
